# Phase 1 UIR pipeline — environment template
# Copy to `.env` and edit. Loaded via python-dotenv at process start.

# --- Weaviate (Phase C/Phase K) ---
# Default points at the host port :18080 which docker-compose.yml maps to
# Weaviate's internal :8080. We use 18080 instead of 8080 because macOS
# dev machines frequently have another listener on :8080 (Python dev
# server, etc.). If you free port 8080 on the host, change the docker
# compose host:port to `"8080:8080"` and update WEAVIATE_URL to
# `http://localhost:8080`.
WEAVIATE_URL=http://localhost:18080
WEAVIATE_API_KEY=                       # leave blank for local Weaviate with anonymous access

# --- Logging ---
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                         # json | text

# --- Models ---
LAYOUTLMV3_MODEL=microsoft/layoutlmv3-base
# Comma-separated EasyOCR language codes (e.g. `en`, `en,fr`). Loader MUST
# split this on `,` and validate each segment against EasyOCR's known langs.
EASYOCR_LANGS=en
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Note: embedding dim is auto-derived from sentence-transformers model metadata.
# Do NOT hardcode EMBEDDING_DIM here; treat it as derived.

# --- Device preference ---
# Comma-separated fallback chain. First available wins.
DEVICE_PREFERENCE=cuda,mps,cpu

# --- Confidence thresholds (warn-only at MVP; chunks always retained) ---
# OPTIONAL OVERRIDES -- code-side defaults in `uir_pipeline.*` are the
# authoritative source. Set these in `.env` only to nudge behavior without
# code changes.
OCR_CONFIDENCE_THRESHOLD=0.85
LAYOUT_CONFIDENCE_THRESHOLD=0.90

# --- I/O ---
INPUT_DIR=./data/input
OUTPUT_DIR=./data/output
LOGS_DIR=./data/logs
