# Phase 1 UIR pipeline — environment template
# Copy to `.env` and edit. Loaded via python-dotenv at process start.

# --- Weaviate (Phase C/Phase K) ---
# Default points at the host port :18080 which docker-compose.yml maps to
# Weaviate's internal :8080. We use 18080 instead of 8080 because macOS
# dev machines frequently have another listener on :8080 (Python dev
# server, etc.). If you free port 8080 on the host, change the docker
# compose host:port to `"8080:8080"` and update WEAVIATE_URL to
# `http://localhost:8080`.
WEAVIATE_URL=http://localhost:18080
WEAVIATE_API_KEY=                       # leave blank for local Weaviate with anonymous access

# --- Logging ---
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                         # json | text

# --- Models ---
LAYOUTLMV3_MODEL=microsoft/layoutlmv3-base
# Comma-separated EasyOCR language codes (e.g. `en`, `en,fr`). Loader MUST
# split this on `,` and validate each segment against EasyOCR's known langs.
EASYOCR_LANGS=en
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Note: embedding dim is auto-derived from sentence-transformers model metadata.
# Do NOT hardcode EMBEDDING_DIM here; treat it as derived.

# --- Device preference ---
# Comma-separated fallback chain. First available wins.
DEVICE_PREFERENCE=cuda,mps,cpu

# --- Audio pipeline (vLLM Whisper + speaker diarization) ---
# vLLM Whisper model ID. Default: openai/whisper-small
# Other options: openai/whisper-tiny, openai/whisper-base, openai/whisper-medium, openai/whisper-large-v3
WHISPER_MODEL_ID=openai/whisper-small
# Optional: force transcription language (ISO 639-1 code, e.g. "en")
# Leave empty for auto-detection
#WHISPER_LANGUAGE=
# Speaker diarization model. Default: pyannote/speaker-diarization-3.1
DIARIZATION_MODEL_ID=pyannote/speaker-diarization-3.1
# Disable speaker diarization (set to 1 to skip, faster processing)
#DIARIZATION_DISABLE=0

# --- Fireworks AI Vision (image pipeline) ---
# Required for the Fireworks AI vision image-analysis pipeline.
# Get your API key from https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=
# Optional: vision model ID (default: accounts/fireworks/models/qwen3-vl-8b-instruct)
# Other good vision models:
#   accounts/fireworks/models/qwen3-vl-32b-instruct
#   accounts/fireworks/models/llama-v4-maverick-17b-128e-instruct
#   accounts/fireworks/models/llama-v4-scout-17b-16e-instruct
#FIREWORKS_VISION_MODEL=accounts/fireworks/models/qwen3-vl-8b-instruct
# Optional: Fireworks API base URL override
#FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# --- Console copilot (grounded chat over your converted documents) ---
# Reuses FIREWORKS_API_KEY / FIREWORKS_BASE_URL above. Only the model differs:
# this one needs to be good at instruction-following over long context, not vision.
#FIREWORKS_CHAT_MODEL=accounts/fireworks/models/minimax-m3

# --- Console auth / sessions ---
# Signs the session cookie. If unset, the app generates one on first boot and
# persists it to `data/.secret_key` (gitignored). SET THIS EXPLICITLY for any
# deployment: anyone who can read the key can forge a session for any user.
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Set to 1 when a TLS terminator sits in front, so the session cookie carries
# the Secure flag. The server binds 127.0.0.1 by default, where plain HTTP is
# fine -- the traffic never leaves the machine.
#
# Binding anywhere routable (HOST=0.0.0.0) over plain HTTP is REFUSED at
# startup: passwords are POSTed and the session cookie is replayed on every
# request, so both would be readable by anyone on the same network. Set
# SESSION_COOKIE_SECURE=1 (with real TLS), or UIR_ALLOW_INSECURE_BIND=1 to
# override on a network you actually trust.
#SESSION_COOKIE_SECURE=1
#HOST=127.0.0.1
#UIR_ALLOW_INSECURE_BIND=1

# There is no self-serve password reset: a reset link needs a mailbox we can't
# reach, and no mail transport is configured. Recovery is an operator action
# that requires filesystem access to the user database:
#     python -m uir_pipeline.auth list
#     python -m uir_pipeline.auth reset alice@example.com
# Resetting a password does NOT invalidate existing session cookies; rotate
# SECRET_KEY to do that.

# --- Console pipeline execution ---
# "process" (default): the orchestrator runs in ONE long-lived child process,
# so a native crash inside Docling (std::bad_alloc -> SIGSEGV) fails that job
# instead of killing the whole server; the parent then respawns the worker.
# The known trigger for that crash -- docling's default PDF backend -- is fixed
# (we pin pypdfium2), so this is now a safety net rather than a workaround.
#
# The worker is started on the first upload and reused, because `import torch`
# + `import docling` costs ~8s and spawning per job paid it every time. Jobs
# are therefore SERIALISED: two concurrent Docling conversions do not fit in
# memory on a typical dev box.
#
# NOTE: the child reads its environment at spawn time. Changing a DOCLING_*
# variable in an already-running server has no effect until the worker is
# respawned. Set them before you start it.
#
# "thread" restores the old in-process behaviour -- no spawn cost, no
# serialisation, but one bad upload takes the console down. Only tests use it.
#UIR_WEB_EXECUTION=process

# Docling reports ConversionStatus.PARTIAL_SUCCESS when some pages fail but
# others convert; it does NOT raise. We treat that as a job failure, because a
# UIR silently missing 70% of a document is worse than no UIR at all. Set this
# to 1 to accept the partial document instead (logs a warning). Note that
# lowering docling's page_batch_size does NOT reduce these errors -- measured,
# 1 and 4 give byte-identical output. The backend is what matters.
#DOCLING_ALLOW_PARTIAL=1

# --- Docling OCR ---
# auto (default): convert without OCR, then re-convert WITH OCR only if the
#   document came back with almost no text -- i.e. it is a scan, whose pages
#   are images. Born-digital PDFs (LaTeX, Word) skip OCR entirely; measured on
#   a 15-page arXiv paper, OCR costs ~50s and adds ~350 characters.
# on:  always OCR. Correct, ~2x slower on every upload.
# off: never OCR. Fast, but a scanned PDF converts to a well-formed EMPTY
#   document with no error -- silent data loss. Only set this if you know
#   every input is born-digital.
#DOCLING_OCR=auto

# --- Confidence thresholds (warn-only at MVP; chunks always retained) ---
# OPTIONAL OVERRIDES -- code-side defaults in `uir_pipeline.*` are the
# authoritative source. Set these in `.env` only to nudge behavior without
# code changes.
OCR_CONFIDENCE_THRESHOLD=0.85
LAYOUT_CONFIDENCE_THRESHOLD=0.90

# --- I/O ---
INPUT_DIR=./data/input
OUTPUT_DIR=./data/output
LOGS_DIR=./data/logs
